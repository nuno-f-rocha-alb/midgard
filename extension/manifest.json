{
  "manifest_version": 3,
  "name": "Midgard New Tab",
  "description": "Abre o dashboard Midgard em cada novo separador e fornece os sites mais visitados.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["topSites", "storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "midgard-newtab@nunobifes",
      "strict_min_version": "115.0"
    }
  }
}
