# ── Midgard ──────────────────────────────────────────────────────────────────
# Copia para .env e preenche. Qualquer conector sem as suas variáveis fica
# simplesmente desativado — não rebenta nada.

# Porta onde o dashboard escuta dentro do container (o compose publica 8484)
MIDGARD_PORT=8484

# ── Beszel (métricas das máquinas) ───────────────────────────────────────────
# Conta de utilizador do beszel (a mesma do login web)
BESZEL_URL=http://dockeralho.lan:8090
BESZEL_EMAIL=
BESZEL_PASSWORD=

# ── Portainer (containers do dockeralho) ─────────────────────────────────────
# Settings → API → Add access token
PORTAINER_URL=https://dockeralho.lan:9443
PORTAINER_API_KEY=
PORTAINER_VERIFY_TLS=false

# ── Pi-hole v6 ───────────────────────────────────────────────────────────────
# Password da web UI (ou app password criada em Settings → Web/API)
# NOTA: o webserver do FTL v6 pode estar numa porta à parte (ex.: :8080) se o :80
# estiver ocupado (lighttpd antigo do v5). Confirma com a API: <url>/api deve
# devolver JSON do Pi-hole. Aponta o URL para a porta onde o /api responde.
PIHOLE_URL=http://pihole.lan:8080
PIHOLE_PASSWORD=

# ── Proxmox ──────────────────────────────────────────────────────────────────
# Um token por nó: Datacenter → Permissions → API Tokens (sem privilege separation
# ou com role PVEAuditor). Formato: nome|url|user@realm!tokenid|secret
# Vários nós separados por vírgula.
PROXMOX_NODES=pve1|https://pve1.lan:8006|root@pam!midgard|SECRET,pve2|https://pve2.lan:8006|root@pam!midgard|SECRET
PROXMOX_VERIFY_TLS=false

# ── Emby ─────────────────────────────────────────────────────────────────────
# Dashboard → Advanced → API Keys
EMBY_URL=http://bifesflix.lan:8096
EMBY_API_KEY=

# ── Crafty Controller ────────────────────────────────────────────────────────
# Settings do user → API Keys
CRAFTY_URL=https://crafty.lan:8443
CRAFTY_TOKEN=
CRAFTY_VERIFY_TLS=false

# ── qBittorrent (atrás do gluetun) ───────────────────────────────────────────
QBIT_URL=http://dockeralho.lan:8080
QBIT_USERNAME=
QBIT_PASSWORD=

# ── Scrutiny (discos da neverNAS) ────────────────────────────────────────────
SCRUTINY_URL=http://nevernas.lan:8080

# ── Speedtest Tracker ────────────────────────────────────────────────────────
# Settings → API Tokens
SPEEDTEST_URL=http://dockeralho.lan:8880
SPEEDTEST_TOKEN=

# ── Routers OpenWrt (GL.iNet + Asus) ─────────────────────────────────────────
# Usa as credenciais da LuCI (user root). Formato: nome|url|user|password
# Requer o endpoint /ubus ativo (vem com a LuCI; senão: opkg install uhttpd-mod-ubus)
# NOTA GL.iNet: a LuCI/ubus está numa porta à parte (tipicamente :8080), não no
# :80 da UI deles — daí o glinet apontar para :8080 aqui.
OPENWRT_ROUTERS=glinet|http://glinet.lan:8080|root|PASS,asus|http://asus-openwrt.lan|root|PASS

# ── Bifrost agent (VPS) ──────────────────────────────────────────────────────
# Usa o MESMO URL e key que o bifrost-frontend usa para o agent — confirma com:
#   docker inspect bifrost-frontend --format '{{range .Config.Env}}{{println .}}{{end}}'
# (a porta do agent é a 8888, não a 8001). O agent só responde por essa via.
BIFROST_AGENT_URL=http://10.10.10.1:8888
BIFROST_AGENT_KEY=

# ── Karakeep / Hoarder (bookmarks de uma lista) ──────────────────────────────
# Settings → API Keys. KARAKEEP_LIST = nome da lista a mostrar no dashboard.
# Guarda páginas com a extensão do Karakeep e mete-as nessa lista.
KARAKEEP_URL=http://dockeralho.lan:3000
KARAKEEP_API_KEY=
KARAKEEP_LIST=Dashboard
