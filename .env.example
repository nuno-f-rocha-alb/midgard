# ── Midgard ──────────────────────────────────────────────────────────────────
# Copia para .env e preenche. Qualquer conector sem as suas variáveis fica
# simplesmente desativado — não rebenta nada.

# Porta onde o dashboard escuta dentro do container (o compose publica 8484)
MIDGARD_PORT=8484

# ── Beszel (métricas das máquinas) ───────────────────────────────────────────
# Conta de utilizador do beszel (a mesma do login web)
BESZEL_URL=http://dockeralho:8090
BESZEL_EMAIL=
BESZEL_PASSWORD=

# ── Portainer (containers do dockeralho) ─────────────────────────────────────
# Settings → API → Add access token
PORTAINER_URL=https://dockeralho:9443
PORTAINER_API_KEY=
PORTAINER_VERIFY_TLS=false

# ── Pi-hole v6 ───────────────────────────────────────────────────────────────
# Password da web UI (ou app password criada em Settings → Web/API)
PIHOLE_URL=http://pihole
PIHOLE_PASSWORD=

# ── Proxmox ──────────────────────────────────────────────────────────────────
# Um token por nó: Datacenter → Permissions → API Tokens (sem privilege separation
# ou com role PVEAuditor). Formato: nome|url|user@realm!tokenid|secret
# Vários nós separados por vírgula.
PROXMOX_NODES=pve1|https://pve1:8006|root@pam!midgard|SECRET,pve2|https://pve2:8006|root@pam!midgard|SECRET
PROXMOX_VERIFY_TLS=false

# ── Emby ─────────────────────────────────────────────────────────────────────
# Dashboard → Advanced → API Keys
EMBY_URL=http://emby:8096
EMBY_API_KEY=

# ── Crafty Controller ────────────────────────────────────────────────────────
# Settings do user → API Keys
CRAFTY_URL=https://crafty:8443
CRAFTY_TOKEN=
CRAFTY_VERIFY_TLS=false

# ── qBittorrent (atrás do gluetun) ───────────────────────────────────────────
QBIT_URL=http://dockeralho:8080
QBIT_USERNAME=
QBIT_PASSWORD=

# ── Scrutiny (discos da neverNAS) ────────────────────────────────────────────
SCRUTINY_URL=http://nevernas:8080

# ── Speedtest Tracker ────────────────────────────────────────────────────────
# Settings → API Tokens
SPEEDTEST_URL=http://dockeralho:8880
SPEEDTEST_TOKEN=

# ── Routers OpenWrt (GL.iNet + Asus) ─────────────────────────────────────────
# Usa as credenciais da LuCI (user root). Formato: nome|url|user|password
# Requer o endpoint /ubus ativo (vem com a LuCI; senão: opkg install uhttpd-mod-ubus)
OPENWRT_ROUTERS=glinet|http://192.168.8.1|root|PASS,asus|http://192.168.1.1|root|PASS

# ── Bifrost agent (VPS) ──────────────────────────────────────────────────────
# O mesmo AGENT_KEY do .env do agent no VPS
BIFROST_AGENT_URL=http://vps:8001
BIFROST_AGENT_KEY=
